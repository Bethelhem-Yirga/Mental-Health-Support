## **💻 Quick Implementation: Mood Calendar Heatmap**

Here's a quick feature to add immediately:

```javascript
// frontend/src/components/MoodCalendar.js
import React from 'react';

function MoodCalendar({ moodEntries }) {
  const getColor = (moodValue) => {
    if (moodValue === undefined) return '#ebedf0';
    switch(moodValue) {
      case 0: return '#216e39'; // Great
      case 1: return '#30a14e'; // Good
      case 2: return '#40c463'; // Okay
      case 3: return '#9be9a8'; // Low
      case 4: return '#ebedf0'; // Very Low
      default: return '#ebedf0';
    }
  };
  
  // Group by date
  const moodMap = {};
  moodEntries.forEach(entry => {
    const date = new Date(entry.date).toDateString();
    moodMap[date] = entry.moodValue;
  });
  
  // Generate last 90 days
  const days = [];
  for (let i = 90; i >= 0; i--) {
    const date = new Date();
    date.setDate(date.getDate() - i);
    const dateStr = date.toDateString();
    days.push({
      date: dateStr,
      moodValue: moodMap[dateStr]
    });
  }
  
  return (
    <div className="mood-calendar">
      <h3>Mood Calendar (Last 90 Days)</h3>
      <div className="calendar-grid">
        {days.map((day, idx) => (
          <div
            key={idx}
            className="calendar-day"
            style={{ backgroundColor: getColor(day.moodValue) }}
            title={`${day.date}: ${day.moodValue !== undefined ? `Mood: ${day.moodValue}` : 'No data'}`}
          />
        ))}
      </div>
    </div>
  );
}

export default MoodCalendar;
```

